# SQLite runtime store
SQL_STORE_ENABLED=true
SQL_STORE_DRIVER=sqlite
SQLITE_DB_PATH=server/data/maistv.sqlite
SQL_STORE_REQUIRE=true
SQL_STORE_DUAL_WRITE_JSON=false
SQL_STORE_CACHE_TTL_MS=1200

# WhatsApp runtime split
WHATSAPP_HTTP_ENABLED=true
WHATSAPP_WEBHOOK_CHAT_ONLY=false
WHATSAPP_SCHEDULERS_ENABLED=false
SUPPORT_FLOW_EXECUTION_ENABLED=true
WHATSAPP_STORE_CACHE_TTL_MS=3000
WHATSAPP_MAX_MESSAGES_PER_CONVERSATION=200
WHATSAPP_MESSAGE_LIST_CACHE_MAX_ENTRIES=500
WHATSAPP_MESSAGE_RESPONSE_CACHE_MAX_ENTRIES=300
WHATSAPP_MEDIA_PROXY_CACHE_MAX_BYTES=10485760

# Chatbot. Em homologacao/auditoria mantenha desligado e com dry-run.
CHATBOT_ENABLED=false
CHATBOT_DRY_RUN=true
CHATBOT_BACKEND_RUNTIME_ENABLED=false
CHATBOT_FRONTEND_PROCESSING_ENABLED=false
CHATBOT_FLOW_SOURCE=postgres
CHATBOT_DRY_RUN_LOG_ENABLED=false
CHATBOT_POSTGRES_RUNTIME_ENABLED=false
CHATBOT_POSTGRES_OUTBOUND_ENABLED=false
CHATBOT_POSTGRES_ALLOWED_ROUTES=vendas
CHATBOT_POSTGRES_ALLOWED_FLOW_IDS=
CHATBOT_POSTGRES_ALLOW_ASSIGNED_CONVERSATIONS=false
CHATBOT_POSTGRES_MAX_OUTPUTS=10
CHATBOT_POSTGRES_BOT_USER_ID=chatbot-postgres

# Assignment PostgreSQL. Ativar primeiro somente para vendas em homologacao.
ASSIGNMENT_WORKER_ENABLED=false
ASSIGNMENT_ENQUEUE_ENABLED=false
ASSIGNMENT_ALLOWED_ROUTES=vendas
ASSIGNMENT_WORKER_CONCURRENCY=2
ASSIGNMENT_MAX_QUEUE_AGE_MINUTES=60
ASSIGNMENT_PRESENCE_HEARTBEAT_MS=30000
ASSIGNMENT_PRESENCE_TTL_SECONDS=90

# Audio transcription with Whisper
WHISPER_MODEL=base
WHISPER_LANGUAGE=pt
WHISPER_TIMEOUT_MS=180000
WHISPER_TMP_DIR=
WHISPER_PYTHON_BIN=python
WHISPER_SERVICE_URL=http://127.0.0.1:5054
WHISPER_SERVICE_HOST=127.0.0.1
WHISPER_SERVICE_PORT=5054
WHISPER_SERVICE_WARM=true

# Worker service overrides these in systemd:
# MAISTV_RUNTIME_ROLE=worker
# WHATSAPP_HTTP_ENABLED=false
# WHATSAPP_SCHEDULERS_ENABLED=true
ROUTINE_RENOVADOS_ERRADO_VALIDATION_ENABLED=false
ROUTINE_RENOVADOS_ERRADO_LABEL_NAME=RENOVADOS ERRADO

# API ports
WHATSAPP_SERVER_PORT=5050
WHATSAPP_SERVER_HOST=127.0.0.1
CHECKOUT_SERVER_PORT=5051
CHECKOUT_SERVER_HOST=127.0.0.1
PORT=5053
CHECKOUT_PUBLIC_URL=
MERCADOPAGO_NOTIFICATION_URL=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
VITE_CHECKOUT_TOKEN_API_BASE_URL=
VITE_CHECKOUT_PAYMENTS_API_BASE_URL=
CHECKOUT_RENEWAL_MAX_ATTEMPTS=1
CHECKOUT_RENEWAL_AUTH_TTL_HOURS=6

# Tavinho copiloto IA
OPENAI_API_KEY=
TAVINHO_OPENAI_MODEL=gpt-4.1-mini
TAVINHO_OPENAI_TIMEOUT_MS=45000
TAVINHO_HISTORY_LIMIT=8

# Internal service URLs
LOCAL_WHATSAPP_API_BASE_URL=http://127.0.0.1:5050
WHATSAPP_API_BASE_URL=http://127.0.0.1:5050
LOCAL_CHECKOUT_API_BASE_URL=http://127.0.0.1:5051
CHECKOUT_API_BASE_URL=http://127.0.0.1:5051
LOCAL_CHECKOUT_TOKEN_API_BASE_URL=http://127.0.0.1:5050
CHECKOUT_TOKEN_API_BASE_URL=http://127.0.0.1:5050
CHECKOUT_WHATSAPP_API_URL=http://127.0.0.1:5050

# NewBR checkout renewal auth
NEWBR_CHECKOUT_BASE_URL=https://painel.newbr.top
NEWBR_CHECKOUT_USERNAME=
NEWBR_CHECKOUT_PASSWORD=

# Nova arquitetura de chat (PostgreSQL = fonte da verdade)
CHAT_ARCHITECTURE_ENABLED=false
CHAT_MIRROR_META_WEBHOOK_ENABLED=false
CHAT_DEFAULT_TENANT_ID=maistv
CHAT_API_PORT=5056
LEGACY_AUTH_ME_URL=http://127.0.0.1:5053/api/local/auth/me
VITE_ENABLE_NEW_CHAT_DATA_LAYER=false
VITE_ENABLE_SSE_REALTIME=false
VITE_ENABLE_CHAT_VIRTUALIZATION=true
VITE_CHECKOUT_RENEWAL_WORKER_ENABLED=true
VITE_CHAT_API_BASE_URL=
VITE_SSE_URL=
CHAT_CORS_ORIGINS=
CHAT_DEFAULT_QUEUE_ID=
CHAT_DEFAULT_SERVICE_ID=
CHAT_DEFAULT_ASSIGNED_AGENT_ID=
VITE_CONVERSATION_REFRESH_INTERVAL_MS=300000
VITE_CONVERSATION_SUMMARY_LIMIT=30
VITE_MESSAGE_PAGE_LIMIT=20
VITE_CHAT_MAX_CACHED_MESSAGES_PER_CONVERSATION=200
VITE_CHAT_CACHED_CONVERSATIONS_LIMIT=10
VITE_MEDIA_LAZY_ROOT_MARGIN=300px
POSTGRES_HOST=127.0.0.1
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=maistv
POSTGRES_USER=maistv
POSTGRES_PASSWORD=
POSTGRES_SSL=false
DATABASE_URL=

# BullMQ, cache temporario e Redis Pub/Sub (nao armazena mensagens definitivamente)
REDIS_HOST=127.0.0.1
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# SSE em processo separado; 5054 permanece reservado ao Whisper
SSE_HOST=127.0.0.1
SSE_PORT=5055
SSE_HEARTBEAT_MS=25000
SSE_AUTH_REVALIDATE_MS=60000
SSE_CORS_ORIGINS=

# Filas e painel administrativo (proteger com autenticacao/allowlist)
BULLMQ_PREFIX=maistv
BULLMQ_JOB_ATTEMPTS=5
BULL_BOARD_ENABLED=true
BULL_BOARD_PATH=/admin/queues

# Storage S3 compativel / Cloudflare R2
STORAGE_PROVIDER=s3
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
S3_SIGNED_URL_TTL_SECONDS=300

# Logs estruturados e erros. Sentry e opcional e nao envia PII por padrao.
LOG_LEVEL=info
LOG_REDACT_PATHS=req.headers.authorization,req.headers.cookie,password,token,accessToken
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
